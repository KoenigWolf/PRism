generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Enums
// ============================================================

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum MediaType {
  PAID
  EARNED
  SHARED
  OWNED
}

// ============================================================
// マルチテナント基盤
// ============================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String?  @unique // SSO用のテナント識別子（例: acme-corp）
  plan      String   @default("starter")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe integration
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  // SSO/SAML configuration
  ssoEnabled    Boolean @default(false)
  ssoProvider   String? // "saml", "oidc", "google", "azure-ad"など
  ssoIssuer     String? // SAML Issuer / OIDC Issuer URL
  ssoEntryPoint String? // SAML Entry Point URL
  ssoCert       String? // SAML Certificate (Base64)
  ssoClientId   String? // OIDC Client ID
  ssoClientSecret String? // OIDC Client Secret（暗号化推奨）

  users     User[]
  companies Company[]
  brands    Brand[]
  prItems   PrItem[]
  tags      Tag[]
  notes     Note[]
  auditLogs AuditLog[]
  insights  Insight[]
  rssSources RssSource[]
  collectedPrItems CollectedPrItem[]
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  hashedPassword String
  name           String
  role           Role      @default(MEMBER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  notes     Note[]
  auditLogs AuditLog[]

  @@index([tenantId])
  @@index([email])
}

// ============================================================
// PR分析ドメイン
// ============================================================

model Company {
  id          String    @id @default(uuid())
  name        String
  industry    String?
  website     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  brands Brand[]

  @@index([tenantId])
}

model Brand {
  id          String    @id @default(uuid())
  name        String
  category    String?
  logoUrl     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  prItems    PrItem[]
  rssSources RssSource[]

  @@index([tenantId])
  @@index([companyId])
}

model PrItem {
  id              String     @id @default(uuid())
  title           String
  summary         String?
  sourceType      String
  sourceUrl       String?
  mediaType       MediaType
  channel         String?
  engagementCount Int        @default(0)
  reachCount      Int?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  tags  PrItemTag[]
  notes Note[]

  @@index([tenantId])
  @@index([brandId])
  @@index([mediaType])
  @@index([publishedAt])
  @@index([tenantId, brandId, mediaType])
}

// ============================================================
// タグ・メモ（補助）
// ============================================================

model Tag {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  prItems PrItemTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model PrItemTag {
  prItemId String
  prItem   PrItem @relation(fields: [prItemId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([prItemId, tagId])
}

model Note {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prItemId String
  prItem   PrItem @relation(fields: [prItemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([prItemId])
}

// ============================================================
// 監査ログ
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================
// AIインサイト
// ============================================================

model Insight {
  id        String    @id @default(uuid())
  content   String
  brandIds  String[]
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ============================================================
// RSS自動収集
// ============================================================

model RssSource {
  id          String    @id @default(uuid())
  name        String    // 表示名（例: "資生堂 ニュースルーム"）
  url         String    // RSSフィードURL
  isActive    Boolean   @default(true)
  lastFetched DateTime? // 最終取得日時
  fetchCount  Int       @default(0) // 累計取得件数
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 取得したPR情報を紐付けるブランド
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  collectedItems CollectedPrItem[]

  @@unique([tenantId, url])
  @@index([tenantId])
  @@index([brandId])
}

model CollectedPrItem {
  id           String    @id @default(uuid())
  guid         String    // RSS記事の一意識別子（重複防止用）
  title        String
  summary      String?
  sourceUrl    String?
  publishedAt  DateTime?
  rawData      Json?     // RSS記事の生データ

  // Claude APIによる分類結果
  mediaType    MediaType?
  channel      String?
  isProcessed  Boolean   @default(false)
  processedAt  DateTime?

  // PRItemに変換済みかどうか
  prItemId     String?   @unique

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rssSourceId String
  rssSource   RssSource @relation(fields: [rssSourceId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([rssSourceId, guid])
  @@index([tenantId])
  @@index([rssSourceId])
  @@index([isProcessed])
}
